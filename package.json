{
  "name": "hqxball",
  "version": "1.0.0",
  "main": "main.js",
  "private": true,
  "author": {
    "name": "HQXBALL Team",
    "url": "https://hqxball.com"
  },
  "license": "GPL-3.0",
  "homepage": "https://github.com/imsinanulgen/hqxball-app",
  "description": "HQXBALL",
  "scripts": {
    "start": "electron . --disable-frame-rate-limit --disable-gpu-vsync --no-vblank",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.hqxball.client",
    "productName": "HQXBALL",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "electron": "18.2.0",
    "electron-builder": "^26.8.1"
  }
}
